# Stage environment example
# Copy to .env.stage and adjust values

COMPOSE_PROJECT_NAME=web-cms-stage

# Seed admin should be disabled in stage
SEED_ADMIN_ENABLED=false
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=ChangeMe_Stage_Only
SEED_ADMIN_AUTHORITY_ID=1
SEED_ADMIN_DEFAULT_ROUTER=dashboard/workplace

# Backend
BACKEND_PORT=8080

# Frontend
FRONTEND_PORT=80

# Database credentials
MYSQL_DATABASE=gva
MYSQL_USER=gva
MYSQL_PASSWORD=ChangeMe_Stage_DB
MYSQL_ROOT_PASSWORD=ChangeMe_Stage_Root

# Redis
REDIS_PASSWORD=ChangeMe_Stage_Redis

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=ChangeMe_Stage_Minio
