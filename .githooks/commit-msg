#!/usr/bin/env sh

set -eu

MSG_FILE="$1"
FIRST_LINE="$(sed -n '1p' "$MSG_FILE" | tr -d '\r')"

# Conventional Commits:
# type(scope)!: subject
# type: subject
PATTERN='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?(!)?: .{1,100}$'

if ! printf "%s" "$FIRST_LINE" | grep -Eq "$PATTERN"; then
  cat <<'EOF'
ERROR: Invalid commit message format.

Use Conventional Commits:
  feat(auth): add login captcha
  fix(api): handle empty menu list
  docs: update deployment guide

Allowed types:
  feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert
EOF
  exit 1
fi

