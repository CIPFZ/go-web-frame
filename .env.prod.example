# Production environment example
# Copy to .env.prod and adjust values before deployment

COMPOSE_PROJECT_NAME=web-cms-prod

# Seed admin must be disabled in production
SEED_ADMIN_ENABLED=false
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=DoNotUseInProd
SEED_ADMIN_AUTHORITY_ID=1
SEED_ADMIN_DEFAULT_ROUTER=dashboard/workplace

# Backend
BACKEND_PORT=8080

# Frontend
FRONTEND_PORT=80

# Database credentials
MYSQL_DATABASE=gva
MYSQL_USER=gva
MYSQL_PASSWORD=ReplaceWithStrongProdPassword
MYSQL_ROOT_PASSWORD=ReplaceWithStrongRootPassword

# Redis
REDIS_PASSWORD=ReplaceWithStrongRedisPassword

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=ReplaceWithStrongMinioPassword
